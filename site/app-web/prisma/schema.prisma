  parceiros         parceiros? @relation(fields: [autor_parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model solicitacoes_acesso {
  id                                                                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parceiro_id                                                       String     @db.Uuid
  nome_informado                                                    String
  // cpf_informado é resquício do login antigo (nome + CPF) — segue no banco
  // como opcional só pra não perder o histórico das solicitações antigas.
  cpf_informado                                                     String?
  email_informado                                                   String?
  senha_hash_informada                                              String?
  status                                                            String     @default("pendente")
  criado_em                                                         DateTime   @default(now()) @db.Timestamptz(6)
  decidido_em                                                       DateTime?  @db.Timestamptz(6)
  decidido_por_parceiro_id                                          String?    @db.Uuid
  parceiros_solicitacoes_acesso_decidido_por_parceiro_idToparceiros parceiros? @relation("solicitacoes_acesso_decidido_por_parceiro_idToparceiros", fields: [decidido_por_parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros_solicitacoes_acesso_parceiro_idToparceiros              parceiros  @relation("solicitacoes_acesso_parceiro_idToparceiros", fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([parceiro_id], map: "idx_solicitacoes_acesso_parceiro")
  @@index([status], map: "idx_solicitacoes_acesso_status")
}

// Módulo de Manutenção · Administração — ferramenta interna (não comercial)
// pra acompanhar solicitações de manutenção dos imóveis, do pedido simples
// (cópia de chave) até serviços que envolvem contratar prestador externo.
// imovel_id aponta pra qualquer imóvel (não só os com administração ativa
// cadastrada — muita locação ainda não tem isso registrado formalmente).
model manutencoes {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imovel_id                String                     @db.Uuid
  cliente_proprietario_id  String?                    @db.Uuid
  prestador_id             String?                    @db.Uuid
  titulo                   String
  tipo_servico             String
  urgencia                 String                     @default("media")
  solicitado_por           String?
  custo_estimado           Decimal?                   @db.Decimal(14, 2)
  custo_final              Decimal?                   @db.Decimal(14, 2)
  autorizado_por           String                     @default("pendente")
  chave_posse              String                     @default("imobiliaria")
  chave_com                String?
  chave_atualizado_em      DateTime?                  @db.Timestamptz(6)
  coluna                   String                     @default("solicitado")
  excluido                 Boolean                    @default(false)
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @default(now()) @db.Timestamptz(6)
  imoveis                  imoveis                    @relation(fields: [imovel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientes                 clientes?                  @relation(fields: [cliente_proprietario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros                parceiros?                 @relation(fields: [prestador_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checklist_itens          manutencao_checklist_itens[]
  atividades               manutencao_atividades[]
  notas                    manutencao_notas[]

  @@index([imovel_id], map: "idx_manutencoes_imovel")
  @@index([coluna], map: "idx_manutencoes_coluna")
}

model manutencao_checklist_itens {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manutencao_id String      @db.Uuid
  label         String
  done          Boolean     @default(false)
  ordem         Int         @default(0) @db.SmallInt
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  manutencoes   manutencoes @relation(fields: [manutencao_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([manutencao_id], map: "idx_manut_checklist_manutencao")
}

model manutencao_atividades {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manutencao_id String      @db.Uuid
  tipo          String
  titulo        String
  data          DateTime    @db.Date
  feito         Boolean     @default(false)
  notas         String?
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  manutencoes   manutencoes @relation(fields: [manutencao_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([manutencao_id], map: "idx_manut_atividades_manutencao")
  @@index([data], map: "idx_manut_atividades_data")
}

model manutencao_notas {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manutencao_id String      @db.Uuid
  texto         String
  criado_em     DateTime    @default(now()) @db.Timestamptz(6)
  manutencoes   manutencoes @relation(fields: [manutencao_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([manutencao_id], map: "idx_manut_notas_manutencao")
}
