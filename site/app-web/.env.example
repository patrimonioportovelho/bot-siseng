# Projeto Supabase: siseng (hzmffwgfqtqnhfjjvydd, região São Paulo).
# Pooler em modo transaction (porta 6543) — usado em runtime pelo Prisma Client.
DATABASE_URL="postgresql://postgres.hzmffwgfqtqnhfjjvydd:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Pooler em modo session (porta 5432) — usado só pelas migrations/`prisma db pull`.
DIRECT_URL="postgresql://postgres.hzmffwgfqtqnhfjjvydd:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Motor de documentos — ver bot-siseng/templates/README.md
SUPABASE_URL="https://hzmffwgfqtqnhfjjvydd.supabase.co"
# Cole aqui a "secret key" do projeto (Settings → API Keys → Secret keys).
# É a que substitui a antiga service_role key — nunca a publishable/anon.
SUPABASE_SERVICE_ROLE_KEY="cole-a-secret-key-do-supabase-aqui"

# Usadas pelo NAVEGADOR (Compra e Venda: upload de documento direto pro
# Supabase Storage, sem passar pela função da Vercel — que tem limite fixo
# de 4,5MB). Precisam do prefixo NEXT_PUBLIC_ pra o Next expor no bundle do
# client. A "anon/publishable key" NÃO é secreta — é feita pra ficar
# pública, protegida por política do Supabase, não por estar escondida.
# Pegue em Settings → API Keys → "anon public" (ou "publishable key" nos
# projetos mais novos).
NEXT_PUBLIC_SUPABASE_URL="https://hzmffwgfqtqnhfjjvydd.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="cole-a-anon-public-key-do-supabase-aqui"
# URL do serviço Gotenberg no Railway (converte .docx em .pdf). Deixe em
# branco durante o desenvolvimento para receber o .docx sem converter.
DOCUMENT_CONVERTER_URL=""
# Pasta local com os .docx de verdade (fora do app-web) — usada só em dev.
# Em produção (Vercel) fica vazia e o motor busca do Supabase Storage.
TEMPLATES_LOCAL_DIR="../../templates"

# Gmail SMTP (envio de email) — ver lib/email.ts.
# Conta Gmail que envia os emails automáticos (também é o remetente — o
# Gmail não permite "from" diferente do usuário autenticado).
GMAIL_USER="patrimonioportovelho@gmail.com"
# "Senha de app" gerada em myaccount.google.com/apppasswords — exige
# verificação em duas etapas ativada na conta acima. NÃO é a senha normal
# da conta Google.
GMAIL_APP_PASSWORD="cole-a-senha-de-app-de-16-caracteres-aqui"
# Destino fixo dos emails de Elaboração de Compra e Venda (portal do corretor).
EMAIL_ADM_COMPRA_VENDA="engimob@remax.com.br"
