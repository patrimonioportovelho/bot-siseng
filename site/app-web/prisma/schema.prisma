model adm_imoveis {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_legado            String?      @unique
  data_entrada         DateTime?    @db.Date
  pasta_url            String?
  loja_id              String       @db.Uuid
  cliente_id           String       @db.Uuid
  parceiro_id          String?      @db.Uuid
  imovel_id            String       @db.Uuid
  status               String       @default("Ativo")
  data_assinatura      DateTime?    @db.Date
  prazo_contrato_meses Int?         @db.SmallInt
  valor_transacao      Decimal?     @db.Decimal(14, 2)
  porc_honorario       Decimal?     @db.Decimal(6, 4)
  tx_administracao     Decimal?     @db.Decimal(6, 4)
  valor_cliente        Decimal?     @db.Decimal(14, 2)
  valor_administracao  Decimal?     @db.Decimal(14, 2)
  iptu                 Decimal?     @db.Decimal(14, 2)
  tem_vistoria         Boolean?
  arquivo_vistoria_url String?
  tem_condominio       Boolean?
  condominio           Decimal?     @db.Decimal(14, 2)
  agua                 String?
  uc_caerd             String?
  energia              String?
  uc_energisa          String?
  observacao           String?
  created_at           DateTime     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime     @default(now()) @db.Timestamptz(6)
  clientes             clientes     @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  imoveis              imoveis      @relation(fields: [imovel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lojas                lojas        @relation(fields: [loja_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros            parceiros?   @relation(fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacoes           transacoes[]

  @@index([cliente_id], map: "idx_adm_imoveis_cliente")
  @@index([imovel_id], map: "idx_adm_imoveis_imovel")
  @@index([loja_id], map: "idx_adm_imoveis_loja")
}

