  created_at                                               DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                                               DateTime                 @default(now()) @db.Timestamptz(6)
  chaves                                                   chaves[]
  condicoes_pagamento                                      condicoes_pagamento[]
  encerramentos_transacao                                  encerramentos_transacao?
  movimentacoes                                            movimentacoes[]
  pagamentos                                               pagamentos[]
  recibos_locacao                                          recibos_locacao[]
  transacoes_contrapartes                                  transacoes_contrapartes[]
  adm_imoveis                                              adm_imoveis?             @relation(fields: [adm_imovel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientes_transacoes_cliente_contraparte_idToclientes     clientes                 @relation("transacoes_cliente_contraparte_idToclientes", fields: [cliente_contraparte_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientes_transacoes_cliente_idToclientes                 clientes                 @relation("transacoes_cliente_idToclientes", fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros_transacoes_corretor_contraparte_idToparceiros  parceiros?               @relation("transacoes_corretor_contraparte_idToparceiros", fields: [corretor_contraparte_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros_transacoes_corretor_proprietario_idToparceiros parceiros?               @relation("transacoes_corretor_proprietario_idToparceiros", fields: [corretor_proprietario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  imoveis                                                  imoveis?                 @relation(fields: [imovel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lojas                                                    lojas                    @relation(fields: [loja_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros_transacoes_parceiro_externo_idToparceiros      parceiros?               @relation("transacoes_parceiro_externo_idToparceiros", fields: [parceiro_externo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  gestoes                                                  gestoes?                 @relation(fields: [gestao_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([adm_imovel_id], map: "idx_transacoes_adm_imovel")
  @@index([cliente_id], map: "idx_transacoes_cliente")
  @@index([cliente_contraparte_id], map: "idx_transacoes_contraparte")
  @@index([corretor_contraparte_id], map: "idx_transacoes_corretor_contraparte")
  @@index([corretor_proprietario_id], map: "idx_transacoes_corretor_proprietario")
  @@index([imovel_id], map: "idx_transacoes_imovel")
  @@index([loja_id], map: "idx_transacoes_loja")
  @@index([gestao_id], map: "idx_transacoes_gestao")
}

/// Clientes interessados (compradores/locatários) vinculados a uma
/// transação — pode ser mais de um (ex.: compra em conjunto, cônjuges).
/// cliente_contraparte_id em transacoes continua guardando o primeiro da
/// lista, para compatibilidade com o restante do sistema. Ordem define a
/// sequência em que aparecem no corpo e na assinatura do contrato.
model transacoes_contrapartes {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transacao_id String     @db.Uuid
  cliente_id   String     @db.Uuid
  ordem        Int        @default(0) @db.SmallInt
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  transacoes   transacoes @relation(fields: [transacao_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clientes     clientes   @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([transacao_id, cliente_id])
  @@index([transacao_id], map: "idx_transacoes_contrapartes_transacao")
  @@index([cliente_id], map: "idx_transacoes_contrapartes_cliente")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model usuarios {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome               String
  email              String               @unique
  senha_hash         String
  papel              String
  loja_id            String?              @db.Uuid
  parceiro_id        String?              @db.Uuid
  ativo              Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  documentos_gerados documentos_gerados[]
  metas              metas[]
  lojas              lojas?               @relation(fields: [loja_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros          parceiros?           @relation(fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([loja_id], map: "idx_usuarios_loja")
}

model checklist_conclusoes {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  item_id         String          @db.Uuid
  parceiro_id     String          @db.Uuid
  concluido_em    DateTime        @default(now()) @db.Timestamptz(6)
  checklist_itens checklist_itens @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parceiros       parceiros       @relation(fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([item_id, parceiro_id])
}

model checklist_itens {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo               String
  descricao            String?
  ordem                Int                    @default(0)
  ativo                Boolean                @default(true)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  checklist_conclusoes checklist_conclusoes[]
}

model logs_acesso {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parceiro_id String    @db.Uuid
  tipo_portal String    @default("admin")
  acao        String    @default("login")
  ip          String?
  user_agent  String?
  criado_em   DateTime  @default(now()) @db.Timestamptz(6)
  parceiros   parceiros @relation(fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model logs_alteracao {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parceiro_id   String?    @db.Uuid
  entidade_tipo String
  entidade_id   String?    @db.Uuid
  acao          String
  dados_antes   Json?
  dados_depois  Json?
  criado_em     DateTime   @default(now()) @db.Timestamptz(6)
  parceiros     parceiros? @relation(fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entidade_tipo, entidade_id], map: "idx_logs_alteracao_entidade")
  @@index([parceiro_id], map: "idx_logs_alteracao_parceiro")
}

/// Registro de erros de salvamento (ex.: constraint do banco rejeitando um
/// valor) — antes disso, um erro de salvamento só aparecia na tela na hora
/// (app/error.tsx) e sumia; agora fica registrado pra dar pra consultar
/// depois em Configurações. "visto" marca se um admin já revisou.
model logs_erro {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parceiro_id      String?    @db.Uuid
  entidade_tipo    String
  entidade_id      String?    @db.Uuid
  acao             String
  mensagem         String
  mensagem_tecnica String?
  visto            Boolean    @default(false)
  criado_em        DateTime   @default(now()) @db.Timestamptz(6)
  parceiros        parceiros? @relation(fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([criado_em], map: "idx_logs_erro_criado_em")
  @@index([visto, criado_em], map: "idx_logs_erro_visto")
}

/// DEPRECADA — sem tela de cadastro própria, ninguém escreve mais aqui.
/// O mural do Portal do Corretor passou a usar publicacoes_site (campo
