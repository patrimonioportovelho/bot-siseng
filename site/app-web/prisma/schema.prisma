generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model adm_imoveis {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_legado            String?      @unique
  data_entrada         DateTime?    @db.Date
  pasta_url            String?
  loja_id              String       @db.Uuid
  cliente_id           String       @db.Uuid
  parceiro_id          String?      @db.Uuid
  imovel_id            String       @db.Uuid
  status               String       @default("Ativo")
  data_assinatura      DateTime?    @db.Date
  prazo_contrato_meses Int?         @db.SmallInt
  valor_transacao      Decimal?     @db.Decimal(14, 2)
  porc_honorario       Decimal?     @db.Decimal(6, 4)
  tx_administracao     Decimal?     @db.Decimal(6, 4)
  valor_cliente        Decimal?     @db.Decimal(14, 2)
  valor_administracao  Decimal?     @db.Decimal(14, 2)
  iptu                 Decimal?     @db.Decimal(14, 2)
  tem_vistoria         Boolean?
  arquivo_vistoria_url String?
  tem_condominio       Boolean?
  condominio           Decimal?     @db.Decimal(14, 2)
  agua                 String?
  uc_caerd             String?
  energia              String?
  uc_energisa          String?
  observacao           String?
  // Soft-delete: "Apagar cadastro" marca excluido=true em vez de apagar de
  // verdade — a administração tem histórico real vinculado (transações,
  // documentos gerados). Fica fora das listas e buscas por padrão.
  excluido             Boolean      @default(false)
  created_at           DateTime     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime     @default(now()) @db.Timestamptz(6)
  clientes             clientes     @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  imoveis              imoveis      @relation(fields: [imovel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lojas                lojas        @relation(fields: [loja_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros            parceiros?   @relation(fields: [parceiro_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacoes           transacoes[]

  @@index([cliente_id], map: "idx_adm_imoveis_cliente")
  @@index([imovel_id], map: "idx_adm_imoveis_imovel")
  @@index([loja_id], map: "idx_adm_imoveis_loja")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model andamentos {
  id                            String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  id_legado                     String?                     @unique
  data_inicio                   DateTime?                   @db.Date
  cliente_vendedor_id           String?                     @db.Uuid
  abrir_conta                   Boolean?                    @default(false)
  avaliacao_id                  String                      @db.Uuid
  imovel_id                     String?                     @db.Uuid
  tipo_contrato                 String?
  status_andamento              String                      @default("Em andamento")
  status_andamento_complementar String?
  processo                      String?
  valor_avaliado                Decimal?                    @db.Decimal(14, 2)
  valor_venda                   Decimal?                    @db.Decimal(14, 2)
  tem_entrada                   Boolean?
  valor_recurso                 Decimal?                    @db.Decimal(14, 2)
  valor_fgts                    Decimal?                    @db.Decimal(14, 2)
  subsidio                      Decimal?                    @db.Decimal(14, 2)
  valor_financiado              Decimal?                    @db.Decimal(14, 2)
  observacao                    String?
  data_conclusao                DateTime?                   @db.Date
  excluido                      Boolean                     @default(false)
  // Avaliador bancário responsável por esta avaliação/andamento — só
  // parceiros com funcao = "Avaliador Bancário" aparecem no select (ver
  // lib/parceiros/opcoes.ts e app/financiamento/[id]/page.tsx). É um banco
  // de dados dos avaliadores de cada banco parceiro, não um usuário do
  // sistema (não precisa de login).
  avaliador_id                  String?                     @db.Uuid
  created_at                    DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime                    @default(now()) @db.Timestamptz(6)
  avaliacoes                    avaliacoes                  @relation(fields: [avaliacao_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientes                      clientes?                   @relation(fields: [cliente_vendedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  imoveis                       imoveis?                    @relation(fields: [imovel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parceiros                     parceiros?                  @relation(fields: [avaliador_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lancamentos_financiamento     lancamentos_financiamento[]

  @@index([avaliacao_id], map: "idx_andamentos_avaliacao")
  @@index([imovel_id], map: "idx_andamentos_imovel")
  @@index([avaliador_id], map: "idx_andamentos_avaliador")
}

